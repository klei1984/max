{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "OFF",
                "CMAKE_INSTALL_PREFIX": "/usr/local"
            }
        },
        {
            "name": "base-windows",
            "hidden": true,
            "inherits": "base",
            "description": "Ninja generator. The CI historically used 'MSYS Makefiles'; Ninja is used here because its dependency graph makes no-op rebuilds near-instant and its process-group teardown on Windows does not orphan cc1plus/as.exe when a build is cancelled. NOTE: run each msys2-* preset from its matching MSYS2 shell (mingw32 presets from the MINGW32 shell, mingw64 presets from the MINGW64 shell). A prefix's gcc/clang loads its own runtime DLLs by PATH order, so invoking it from a foreign MSYS2 shell fails the compiler check. Set MSYS2_ROOT to override the default c:/msys64 install location.",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "c:/Program Files/M.A.X. Port"
            }
        },
        {
            "name": "base-windows-x86",
            "hidden": true,
            "inherits": "base-windows",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "c:/Program Files (x86)/M.A.X. Port"
            }
        },
        {
            "name": "base-linux",
            "hidden": true,
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON"
            }
